# Slack Socket Mode 토큰
# Slack App 설정 → Basic Information → App-Level Tokens에서 발급
# connections:write scope 필요
SLACK_APP_TOKEN=xapp-1-...

# Slack Bot 토큰
# Slack App 설정 → OAuth & Permissions에서 발급
# 멀티 워크스페이스: 쉼표로 구분 (예: xoxb-aaa,xoxb-bbb)
SLACK_BOT_TOKEN=xoxb-...

# LLM API 키 — 현재: Google Gemini (무료)
# Google AI Studio에서 발급: https://aistudio.google.com/apikey
GOOGLE_API_KEY=AIza...

# 추후 OpenRouter로 전환 시 아래로 교체:
# OPENROUTER_API_KEY=sk-or-...
# (GOOGLE_API_KEY는 주석 처리)

# 기타 프로바이더 (미사용 시 주석 유지)
# ANTHROPIC_API_KEY=sk-ant-...
# NOUS_API_KEY=...
